# WalletConnect Project ID — get from https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Circle API Key — get from https://console.circle.com
VITE_CIRCLE_API_KEY=

# Arc Network RPC endpoint
VITE_ARC_RPC_URL=https://rpc.arc.network

# Arc Testnet Chain ID (TBD — check https://docs.arc.io before deploying)
VITE_ARC_CHAIN_ID=1789

# Alchemy API Key — for Ethereum, Base, Arbitrum, Polygon RPCs
VITE_ALCHEMY_KEY=

# Circle Entity Secret — for BridgeKit
VITE_CIRCLE_ENTITY_SECRET=

# SwapRouter contract address on Arc Testnet (deploy via Foundry first)
VITE_SWAP_ROUTER_ADDRESS=

# Optional: off-chain quote API URL
# VITE_QUOTE_API_URL=https://api.arc.io
